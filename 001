# 4. 优化算法与目标函数（改为逐时刻NNLS拟合）
# ======================

def interpolate_led_to_sun_grid(led_wavelength: np.ndarray,
                                led_spectra: list,
                                target_wavelength: np.ndarray) -> np.ndarray:
    """将5路LED光谱插值到太阳光谱的波长网格，返回矩阵A: (num_wl, 5)"""
    A_columns = []
    for spectrum in led_spectra:
        f = interp1d(led_wavelength, spectrum, kind='linear', bounds_error=False, fill_value="extrapolate")
        A_columns.append(f(target_wavelength))
    A = np.stack(A_columns, axis=1)  # shape: (num_wl, 5)
    # 保证非负
    A[A < 0] = 0.0
    return A

def normalize_columns_minmax(A: np.ndarray) -> np.ndarray:
    """对矩阵A按列进行min-max归一化，避免列为常数时产生除零。"""
    A_norm = A.copy().astype(float)
    for j in range(A.shape[1]):
        col = A[:, j]
        cmin, cmax = np.min(col), np.max(col)
        if cmax - cmin < 1e-12:
            A_norm[:, j] = 0.0
        else:
            A_norm[:, j] = (col - cmin) / (cmax - cmin)
    return A_norm

def fit_weights_nnls(A: np.ndarray, sun_spectra: np.ndarray) -> np.ndarray:
    """对每个时刻独立进行NNLS拟合（按形状归一化），返回权重矩阵W: (num_times, 5)"""
    # 目标向量按时刻min-max归一化到[0,1]
    def mm(v: np.ndarray) -> np.ndarray:
        vmin, vmax = np.min(v), np.max(v)
        if vmax - vmin < 1e-12:
            return np.zeros_like(v)
        return (v - vmin) / (vmax - vmin)

    num_times = sun_spectra.shape[0]
    W = np.zeros((num_times, A.shape[1]))
    for t in range(num_times):
        b = mm(sun_spectra[t])
        w, _ = nnls(A, b)
        # 归一化到和为1，便于解读
        s = w.sum()
        if s > 1e-12:
            w = w / s
        W[t] = w
    return W

def synthesize_from_weights(A: np.ndarray, W: np.ndarray) -> np.ndarray:
    """根据W合成每个时刻的光谱，返回形状(num_times, num_wl)"""
    return (A @ W.T).T

def cosine_similarity(a: np.ndarray, b: np.ndarray) -> float:
    na = np.linalg.norm(a)
    nb = np.linalg.norm(b)
    if na < 1e-12 or nb < 1e-12:
        return 0.0
    return float(np.dot(a, b) / (na * nb))

def spectral_similarity(synthetic_spectra: np.ndarray, sun_spectra: np.ndarray) -> np.ndarray:
    """计算光谱相似度（对每个时刻的余弦相似度，向量按L2归一化）"""
    sims = []
    for syn, sun in zip(synthetic_spectra, sun_spectra):
        sims.append(cosine_similarity(syn, sun))
    return np.array(sims)


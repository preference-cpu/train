def main():
    # 1. 加载原始数据
    raw_data = load_data()

    # 2. 数据预处理
    processed_data, outlier_report, scaler = preprocess_data(raw_data)

    # 3. 波长对齐（将LED插值到太阳光谱波长网格）
    A_raw = interpolate_led_to_sun_grid(
        led_wavelength=processed_data['led_wavelength'],
        led_spectra=processed_data['led_spectra'],
        target_wavelength=processed_data['sun_wavelength']
    )
    # 用于形状拟合的列归一化基A
    A_shape = normalize_columns_minmax(A_raw)

    # 4. 逐时刻用NNLS求解最优权重（形状域）
    print("\n开始逐时刻NNLS拟合...")
    W = fit_weights_nnls(A_shape, processed_data['sun_spectra'])  # shape: (T, 5)

    # 5. 合成光谱与相似度（形状域）
    synthetic_spectra_shape = synthesize_from_weights(A_shape, W)  # shape: (T, num_wl)
    similarities = spectral_similarity(synthetic_spectra_shape, np.array([
        (s - np.min(s)) / (np.max(s) - np.min(s)) if (np.max(s) - np.min(s)) > 1e-12 else np.zeros_like(s)
        for s in processed_data['sun_spectra']
    ]))
    total_similarity = float(np.mean(similarities))

    # 生成未归一化的合成光谱（用于物理量与高级指标计算）
    synthetic_spectra_full = synthesize_from_weights(A_raw, W)
    processed_data['synthetic_spectra_full'] = synthetic_spectra_full

    # 6. 输出结果摘要
    print("\n===== 优化结果摘要 =====")
    print(f"平均相似度: {total_similarity:.4f}")
    print(f"达到≥0.90的时间点比例: {(np.mean(similarities >= 0.90) * 100):.2f}%")
    print(f"最低相似度: {np.min(similarities):.4f}")

    # 代表性时间点附加显示CCT、Duv、mel-DER、Rf、Rg
    reps = [0, len(processed_data['sun_times']) // 2, len(processed_data['sun_times']) - 1]
    print("\n代表性时间点指标(合成光谱):")
    for i in reps:
        wl = processed_data['sun_wavelength']
        spd_syn = synthetic_spectra_full[i]
        Rf, Rg = compute_tm30_rf_rg(wl, spd_syn)
        CCT_v, Duv_v = compute_cct_duv(wl, spd_syn)
        melDER_v = compute_mel_DER(wl, spd_syn)
        print(f"{processed_data['sun_times'][i]} | Rf={Rf:.1f}, Rg={Rg:.1f}, CCT={CCT_v:.0f}K, Duv={Duv_v:.4f}, mel-DER={melDER_v:.3f}")

    # 7. 可视化与保存结果（形状域）
    visualize_results(processed_data, synthetic_spectra_shape, W)
    save_results(processed_data, W, similarities)


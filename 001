def visualize_results(data, synthetic_spectra, optimal_weights):
    """可视化优化结果：绘制早/中/晚三个代表性时间点的光谱形状对比，以及权重热图"""
    # 选择代表性时间点
    time_indices = [0, len(data['sun_times']) // 2, len(data['sun_times']) - 1]
    plt.figure(figsize=(12, 10))

    # 为对比形状，将两个光谱各自做[0,1]归一化
    def mm(v):
        v = np.asarray(v)
        vmin, vmax = np.min(v), np.max(v)
        if vmax - vmin < 1e-12:
            return np.zeros_like(v)
        return (v - vmin) / (vmax - vmin)

    for i, idx in enumerate(time_indices):
        plt.subplot(3, 1, i + 1)
        plt.plot(data['sun_wavelength'], mm(data['sun_spectra'][idx]),
                 label='太阳光谱', color='orange', linewidth=2)
        plt.plot(data['sun_wavelength'], mm(synthetic_spectra[idx]),
                 label='合成光谱', color='blue', linestyle='--', linewidth=2)
        plt.title(f'时间点: {data["sun_times"][idx]}')
        plt.xlabel('波长 (nm)')
        plt.ylabel('归一化光强')
        plt.legend()
        plt.grid(alpha=0.3)

    plt.tight_layout()
    plt.savefig('光谱对比图.png', dpi=300)
    plt.show()

    # 绘制权重变化热图
    plt.figure(figsize=(10, 6))
    sns.heatmap(optimal_weights, annot=False, cmap='viridis',
                xticklabels=data['led_channels'],
                yticklabels=data['sun_times'])
    plt.title('各时间点LED通道权重分布')
    plt.tight_layout()
    plt.savefig('权重分布热图.png', dpi=300)
    plt.show()

def save_results(data, optimal_weights, similarities):
    """保存优化结果"""
    df_results = pd.DataFrame(optimal_weights, columns=data['led_channels'])
    df_results.insert(0, '时间点', data['sun_times'])
    df_results['相似度'] = similarities

    # 计算并附加高级指标（针对合成与太阳光谱）
    syn_metrics = {
        'Rf_syn': [], 'Rg_syn': [], 'CCT_syn': [], 'Duv_syn': [], 'melDER_syn': []
    }
    sun_metrics = {
        'Rf_sun': [], 'Rg_sun': [], 'CCT_sun': [], 'Duv_sun': [], 'melDER_sun': []
    }
    for idx in range(len(data['sun_times'])):
        wl = data['sun_wavelength']
        syn_spd = data.get('synthetic_spectra_full', None)
        syn_vals = syn_spd[idx] if syn_spd is not None else np.zeros_like(wl)
        sun_vals = data['sun_spectra'][idx]

        Rf_s, Rg_s = compute_tm30_rf_rg(wl, syn_vals)
        CCT_s, Duv_s = compute_cct_duv(wl, syn_vals)
        melDER_s = compute_mel_DER(wl, syn_vals)

        Rf_t, Rg_t = compute_tm30_rf_rg(wl, sun_vals)
        CCT_t, Duv_t = compute_cct_duv(wl, sun_vals)
        melDER_t = compute_mel_DER(wl, sun_vals)

        syn_metrics['Rf_syn'].append(Rf_s)
        syn_metrics['Rg_syn'].append(Rg_s)
        syn_metrics['CCT_syn'].append(CCT_s)
        syn_metrics['Duv_syn'].append(Duv_s)
        syn_metrics['melDER_syn'].append(melDER_s)

        sun_metrics['Rf_sun'].append(Rf_t)
        sun_metrics['Rg_sun'].append(Rg_t)
        sun_metrics['CCT_sun'].append(CCT_t)
        sun_metrics['Duv_sun'].append(Duv_t)
        sun_metrics['melDER_sun'].append(melDER_t)

    for k, v in syn_metrics.items():
        df_results[k] = v
    for k, v in sun_metrics.items():
        df_results[k] = v

    df_results.to_csv('问题三优化结果.csv', index=False, encoding='utf-8-sig')
    print("\n优化结果已保存至: 问题三优化结果.csv")
    return df_results


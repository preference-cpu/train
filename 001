# 5. 结果可视化与保存
# ======================
def visualize_results(data, synthetic_spectra, optimal_weights):
    """可视化优化结果"""
    # 绘制代表性时间点的光谱对比图
    time_indices = [0, len(data['sun_times'])//2, -1]  # 早、中、晚三个时间点
    plt.figure(figsize=(12, 10))

    for i, idx in enumerate(time_indices):
        plt.subplot(3, 1, i+1)
        plt.plot(data['sun_wavelength'], data['sun_spectra_normalized'][idx],
                 label='太阳光谱', color='orange', linewidth=2)
        plt.plot(data['sun_wavelength'], synthetic_spectra[idx],
                 label='合成光谱', color='blue', linestyle='--', linewidth=2)
        plt.title(f'时间点: {data["sun_times"][idx]}')
        plt.xlabel('波长 (nm)')
        plt.ylabel('标准化光强')
        plt.legend()
        plt.grid(alpha=0.3)

    plt.tight_layout()
    plt.savefig('光谱对比图.png', dpi=300)
    plt.show()

    # 绘制权重变化热图
    plt.figure(figsize=(10, 6))
    sns.heatmap(optimal_weights, annot=False, cmap='viridis',
                xticklabels=data['led_channels'],
                yticklabels=data['sun_times'])
    plt.title('各时间点LED通道权重分布')
    plt.tight_layout()
    plt.savefig('权重分布热图.png', dpi=300)
    plt.show()

def save_results(data, optimal_weights, similarities):
    """保存优化结果"""
    df_results = pd.DataFrame(optimal_weights, columns=data['led_channels'])
    df_results.insert(0, '时间点', data['sun_times'])
    df_results['相似度'] = similarities
    df_results.to_csv('问题三优化结果.csv', index=False, encoding='utf-8-sig')
    print("\n优化结果已保存至: 问题三优化结果.csv")
    return df_results

# ======================
# 主函数
# ======================
def main():
    # 1. 加载原始数据
    raw_data = load_data()

    # 2. 数据预处理
    processed_data, outlier_report, scaler = preprocess_data(raw_data)

    # 3. 数据补充
    supplementary_data = supplement_data(processed_data)

    # 4. 设置优化参数
    num_weights = len(processed_data['sun_times']) * 5
    bounds = [(0, 1)] * num_weights  # 权重范围

    # 5. 运行优化算法
    print("\n开始优化计算...")
    result = differential_evolution(
        func=objective_function,
        bounds=bounds,
        args=(processed_data['led_spectra_normalized'], processed_data['sun_spectra_normalized']),
        popsize=20,
        mutation=(0.8, 1.2),
        recombination=0.9,
        maxiter=200,
        tol=1e-4,
        disp=True,
        workers=-1
    )

    # 6. 处理优化结果
    optimal_weights = result.x.reshape(-1, 5)
    synthetic_spectra_norm = calculate_synthetic_spectrum(
        result.x, processed_data['led_spectra_normalized']
    )
    similarities = spectral_similarity(synthetic_spectra_norm, processed_data['sun_spectra_normalized'])
    total_similarity = np.sum(similarities)
    # 使用相同权重在原始LED光谱上合成物理SPD
    synthetic_spectra_physical = calculate_synthetic_spectrum(
        result.x, processed_data['led_spectra']
    )
    # 7. 计算并汇总指标
    print("\n计算 CCT、Duv、Rf、Rg、mel-DER 指标...")
    metrics_df = compute_metrics_batch(
        processed_data['led_wavelength'], synthetic_spectra_physical, supplementary_data
    )
    # 8. 输出结果摘要
    print("\n===== 优化结果摘要 =====")
    print(f"优化成功: {result.success}")
    print(f"迭代次数: {result.nit}")
    print(f"总相似度: {total_similarity:.6f}")
    print("\n代表性时间点权重与指标:")
    for i in range(min(5, len(processed_data['sun_times']))):
        r = metrics_df.iloc[i]
        print(f"{processed_data['sun_times'][i]}: 权重={[round(w, 4) for w in optimal_weights[i]]}, "
              f"Rf={r['Rf']:.2f}, Rg={r['Rg']:.2f}, CCT={r['CCT']:.1f}K, Duv={r['Duv']:.5f}, mel-DER={r['mel-DER']:.3f}")
    # 9. 可视化与保存结果
    visualize_results(processed_data, synthetic_spectra_norm, optimal_weights)
    # 将指标也保存
    df_results = pd.DataFrame(optimal_weights, columns=processed_data['led_channels'])
    df_results.insert(0, '时间点', processed_data['sun_times'])
    df_results['相似度'] = similarities
    for col in metrics_df.columns:
        df_results[col] = metrics_df[col]
    df_results.to_csv('问题三优化结果.csv', index=False, encoding='utf-8-sig')
    print("\n优化结果已保存至: 问题三优化结果.csv")

if __name__ == '__main__':
    mp.freeze_support()
    main()

def supplement_data(data):
    """补充必要的数据（根据CIE标准和题目要求）"""
    # 必须补充：CIE 1931标准色匹配函数（用于颜色参数计算）{insert\_element\_0\_}
    wavelengths = data['led_wavelength']

    # 基于CIE标准数据插值生成380-780nm的色匹配函数
    base_wl = np.array([380, 400, 450, 500, 550, 600, 650, 700, 780])
    x_bar = np.array([0.0014, 0.0042, 0.3483, 0.0049, 0.9950, 0.6310, 0.0010, 0.0000, 0.0000])
    y_bar = np.array([0.0000, 0.0001, 0.0483, 0.3230, 0.8700, 0.3810, 0.0030, 0.0000, 0.0000])
    z_bar = np.array([0.0065, 0.0230, 1.7470, 0.0093, 0.0003, 0.0008, 0.0000, 0.0000, 0.0000])

    x_interp = interp1d(base_wl, x_bar, kind='cubic', fill_value="extrapolate")
    y_interp = interp1d(base_wl, y_bar, kind='cubic', fill_value="extrapolate")
    z_interp = interp1d(base_wl, z_bar, kind='cubic', fill_value="extrapolate")

    # 封装补充数据（使用英文变量名避免语法问题）
    supplementary_data = {
        'cie_x': x_interp(wavelengths),
        'cie_y': y_interp(wavelengths),
        'cie_z': z_interp(wavelengths),
        # 可选补充：视黑素作用光谱（用于mel-DER计算）{insert\_element\_1\_}
        'melanopic': interp1d(
            np.array([420, 440, 460, 480, 500, 520, 540]),
            np.array([0.13, 0.45, 0.84, 1.00, 0.67, 0.22, 0.03]),
            kind='cubic', fill_value="extrapolate"
        )(wavelengths)
    }

    return supplementary_data  # 修正：在函数内返回数据
# ======================
# 4. 优化算法与目标函数
# ======================
def calculate_synthetic_spectrum(weights, led_spectra):
    """计算合成光谱"""
    num_times = len(weights) // 5
    synthetic_spectra = []

    for t in range(num_times):
        t_weights = weights[t * 5: (t + 1) * 5]
        # 权重归一化
        sum_weights = np.sum(t_weights)
        t_weights = t_weights / sum_weights if sum_weights > 1e-10 else t_weights
        # 计算合成光谱
        spectrum_t = np.sum([t_weights[i] * led_spectra[i] for i in range(5)], axis=0) + 1e-8
        synthetic_spectra.append(spectrum_t)

    return np.array(synthetic_spectra)

def spectral_similarity(synthetic_spectra, sun_spectra):
    """计算光谱相似度（余弦相似度）"""
    similarities = []
    for syn, sun in zip(synthetic_spectra, sun_spectra):
        dot_product = np.dot(syn, sun)
        norm_syn = np.linalg.norm(syn)
        norm_sun = np.linalg.norm(sun)

        cos_sim = dot_product / (norm_syn * norm_sun) if (norm_syn > 1e-10 and norm_sun > 1e-10) else 0.0
        similarities.append(cos_sim)

    return np.array(similarities)

def objective_function(weights, led_spectra, sun_spectra):
    """优化目标函数"""
    num_times = len(weights) // 5
    penalty = 0

    # 权重约束惩罚
    for t in range(num_times):
        t_weights = weights[t * 5: (t + 1) * 5]
        sum_weights = np.sum(t_weights)

        # 权重和偏离1的惩罚
        penalty += (sum_weights - 1) **4 * 10000

        # 权重非负惩罚
        for w in t_weights:
            if w < 0:
                penalty += (-w)** 2 * 10000

    synthetic_spectra = calculate_synthetic_spectrum(weights, led_spectra)
    similarities = spectral_similarity(synthetic_spectra, sun_spectra)
    total_similarity = np.sum(similarities)

    return -total_similarity + penalty

# ======================
# 4.1 颜色与生理指标计算
# ======================

def _spd_from_arrays(wavelengths: np.ndarray, values: np.ndarray, name: str = "Test") -> SpectralDistribution:
    data = dict(zip(wavelengths.astype(float), values.astype(float)))
    sd = SpectralDistribution(data, name=name)
    return sd.copy().align(SPECTRAL_SHAPE_DEFAULT)


def compute_tm30_metrics(wavelengths: np.ndarray, spd: np.ndarray) -> tuple[float, float, float, float]:
    """返回 (Rf, Rg, CCT, Duv)。"""
    sd = _spd_from_arrays(wavelengths, spd, name="Synthetic")
    spec = tm3018.colour_fidelity_index_ANSIIESTM3018(sd, additional_data=True)
    return float(spec.R_f), float(spec.R_g), float(spec.CCT), float(spec.D_uv)


def compute_mel_der(wavelengths: np.ndarray, spd: np.ndarray, melanopic: np.ndarray) -> float:
    """mel-DER = (∑S·S_mel/∑S·V)/(∑D65·S_mel/∑D65·V)。"""
    v_sd = SDS_LEFS_PHOTOPIC['CIE 1924 Photopic Standard Observer']
    v_vals = np.interp(wavelengths, v_sd.wavelengths, v_sd.values)
    d65_sd = SDS_ILLUMINANTS['D65']
    d65_vals = np.interp(wavelengths, d65_sd.wavelengths, d65_sd.values)
    S = np.clip(spd.astype(float), 0, None)
    V = np.clip(v_vals.astype(float), 0, None)
    M = np.clip(melanopic.astype(float), 0, None)
    D65 = np.clip(d65_vals.astype(float), 0, None)
    mer_test = (S * M).sum() / max((S * V).sum(), 1e-12)
    mer_d65 = (D65 * M).sum() / max((D65 * V).sum(), 1e-12)
    return float(mer_test / max(mer_d65, 1e-12))


def compute_metrics_batch(wavelengths: np.ndarray, spectra: np.ndarray, supplementary_data: dict) -> pd.DataFrame:
    results = {'Rf': [], 'Rg': [], 'CCT': [], 'Duv': [], 'mel-DER': []}
    melanopic = supplementary_data.get('melanopic')
    if melanopic is None or len(melanopic) != len(wavelengths):
        raise ValueError('补充数据中的 melanopic 缺失或长度不匹配')
    for i in range(spectra.shape[0]):
        spd = spectra[i]
        try:
            Rf, Rg, CCT, Duv = compute_tm30_metrics(wavelengths, spd)
        except Exception:
            Rf, Rg, CCT, Duv = np.nan, np.nan, np.nan, np.nan
        try:
            mel_der = compute_mel_der(wavelengths, spd, melanopic)
        except Exception:
            mel_der = np.nan
        results['Rf'].append(Rf)
        results['Rg'].append(Rg)
        results['CCT'].append(CCT)
        results['Duv'].append(Duv)
        results['mel-DER'].append(mel_der)
    return pd.DataFrame(results)


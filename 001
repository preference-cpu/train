def load_data(file_path='附录.xlsx'):
    """加载并整理题目提供的数据"""
    try:
        if not os.path.exists(file_path):
            raise FileNotFoundError(f"数据文件 '{file_path}' 不存在")

        # 加载问题3相关数据
        # Problem 2: LED光谱数据
        df_led = pd.read_excel(file_path, sheet_name='Problem 2_LED_SPD')
        # Problem 3: 太阳光谱时间序列数据
        df_sun = pd.read_excel(file_path, sheet_name='Problem 3 SUN_SPD')

        # 提取波长数据（处理字符串格式的波长）
        led_wavelength = df_led['波长'].str.extract(r'(\d+)').astype(float).values.flatten()
        sun_wavelength = df_sun['波长'].str.extract(r'(\d+)').astype(float).values.flatten()

        # 提取光谱数据
        led_channels = ['Blue', 'Green', 'Red', 'Warm White', 'Cold White']
        led_spectra = [df_led[channel].values for channel in led_channels]

        sun_times = df_sun.columns[1:]  # 时间点
        sun_spectra = df_sun[sun_times].values.T  # 转置为(时间点, 波长)格式

        print(f"数据加载完成: {len(sun_times)}个时间点, 波长范围: {led_wavelength[0]}-{led_wavelength[-1]}nm")

        return {
            'led_wavelength': led_wavelength,
            'led_spectra': led_spectra,
            'led_channels': led_channels,
            'sun_wavelength': sun_wavelength,
            'sun_spectra': sun_spectra,
            'sun_times': sun_times
        }

    except Exception as e:
        print(f"数据加载错误: {str(e)}")
        raise


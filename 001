def preprocess_data(raw_data):
    """数据预处理主函数"""
    processed_data = raw_data.copy()

    # 2.1 缺失值处理
    processed_data = handle_missing_values(processed_data)

    # 2.2 异常值检测与处理
    processed_data, outlier_report = detect_and_handle_outliers(processed_data)

    # 2.3 数据转换（标准化副本用于评估和可视化，不改变原始强度）
    processed_data, scaler = normalize_spectra(processed_data)

    return processed_data, outlier_report, scaler

def handle_missing_values(data):
    """处理缺失值"""
    # 检查LED光谱数据
    led_missing = [np.isnan(spectrum).sum() for spectrum in data['led_spectra']]
    # 检查太阳光谱数据
    sun_missing = np.isnan(data['sun_spectra']).sum()

    print(f"\n缺失值检查:")
    print(f"LED光谱各通道缺失值数量: {dict(zip(data['led_channels'], led_missing))}")
    print(f"太阳光谱总缺失值数量: {sun_missing}")

    # 若存在缺失值，使用线性插值处理（时间序列特性适合线性插值）
    if any(count > 0 for count in led_missing) or sun_missing > 0:
        print("发现缺失值，应用线性插值法填充...")

        # 处理LED光谱缺失值
        processed_led = []
        for spectrum in data['led_spectra']:
            mask = np.isnan(spectrum)
            if np.any(mask):
                # 创建插值函数
                interp_func = interp1d(
                    data['led_wavelength'][~mask],
                    spectrum[~mask],
                    kind='linear',
                    fill_value="extrapolate"
                )
                # 插值填充
                filled = interp_func(data['led_wavelength'])
                processed_led.append(filled)
            else:
                processed_led.append(spectrum)
        data['led_spectra'] = processed_led

        # 处理太阳光谱缺失值
        sun_spectra = data['sun_spectra']
        for i in range(sun_spectra.shape[0]):
            spectrum = sun_spectra[i]
            mask = np.isnan(spectrum)
            if np.any(mask):
                interp_func = interp1d(
                    data['sun_wavelength'][~mask],
                    spectrum[~mask],
                    kind='linear',
                    fill_value="extrapolate"
                )
                sun_spectra[i] = interp_func(data['sun_wavelength'])
        data['sun_spectra'] = sun_spectra

    return data

def detect_and_handle_outliers(data):
    """检测并处理异常值"""
    outlier_report = {}

    # 对每个LED通道检测异常值
    led_outliers = {}
    for i, (channel, spectrum) in enumerate(zip(data['led_channels'], data['led_spectra'])):
        # 使用IQR法检测异常值
        q1 = np.percentile(spectrum, 25)
        q3 = np.percentile(spectrum, 75)
        iqr = q3 - q1
        lower_bound = q1 - 1.5 * iqr
        upper_bound = q3 + 1.5 * iqr

        outliers = (spectrum < lower_bound) | (spectrum > upper_bound)
        outlier_count = np.sum(outliers)
        led_outliers[channel] = {
            'count': outlier_count,
            'percentage': (outlier_count / len(spectrum)) * 100,
            'indices': np.where(outliers)[0]
        }

        # 可视化异常值（箱线图）
        plt.figure(figsize=(8, 4))
        sns.boxplot(y=spectrum)
        plt.title(f'{channel}通道光谱数据异常值检测')
        plt.ylabel('光强')
        plt.savefig(f'{channel}_outliers.png', dpi=300)
        plt.close()

    # 对太阳光谱检测异常值
    sun_outliers = []
    for i, time in enumerate(data['sun_times']):
        spectrum = data['sun_spectra'][i]
        q1 = np.percentile(spectrum, 25)
        q3 = np.percentile(spectrum, 75)
        iqr = q3 - q1
        lower_bound = q1 - 1.5 * iqr
        upper_bound = q3 + 1.5 * iqr

        outliers = (spectrum < lower_bound) | (spectrum > upper_bound)
        outlier_count = np.sum(outliers)
        sun_outliers.append({
            'time': time,
            'count': outlier_count,
            'percentage': (outlier_count / len(spectrum)) * 100,
            'indices': np.where(outliers)[0]
        })

    # 异常值报告
    outlier_report = {
        'led': led_outliers,
        'sun': sun_outliers
    }

    # 打印异常值摘要
    print("\n异常值检测摘要:")
    for channel, stats in led_outliers.items():
        print(f"{channel}通道: {stats['count']}个异常值 ({stats['percentage']:.2f}%)")

    # 策略：保留异常值（光谱数据中的极端值可能是真实物理现象）
    print("异常值处理策略: 保留所有异常值（可能反映真实光谱特性）")

    return data, outlier_report

def normalize_spectra(data):
    """生成标准化副本（不改变原始数据），用于相似度评估与可视化"""
    # 使用按列的最小-最大归一化到[0,1]，以比较形状
    def minmax_normalize(v: np.ndarray) -> np.ndarray:
        v_min = np.min(v)
        v_max = np.max(v)
        if v_max - v_min < 1e-12:
            return np.zeros_like(v)
        return (v - v_min) / (v_max - v_min)

    processed_led = [minmax_normalize(s) for s in data['led_spectra']]
    processed_sun = [minmax_normalize(s) for s in data['sun_spectra']]

    data['led_spectra_normalized'] = processed_led
    data['sun_spectra_normalized'] = processed_sun

    print("\n数据标准化完成: 生成[0,1]范围的形状对比副本")

    # 兼容旧返回结构
    dummy_scaler = {'led_scaler': None, 'sun_scaler': None}
    return data, dummy_scaler

